{
  "manifest_version": 3,
  "name": "QR Code Scanner & Generator",
  "version": "3.1.5",
  "description": "QR Code Scanner & Generator",
  "author": "Pro Bandey",
  "homepage_url": "https://github.com/MegaMind-Solution",

  "icons": {
    "16": "icons/16.png",
    "32": "icons/32.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  },

  "permissions": [
    "activeTab",
    "contextMenus",
    "storage",
    "clipboardWrite",
    "clipboardRead"
  ],

  "action": {
    "default_icon": {
      "16": "icons/16.png",
      "32": "icons/32.png",
      "48": "icons/48.png",
      "128": "icons/128.png"
    }
  },

  "sidebar_action": {
    "default_icon": "icons/48.png",
    "default_title": "QR Code Scanner & Generator",
    "default_panel": "index.html"
  },

  "background": {
    "scripts": ["js/background.js"]
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["js/content.js"]
    }
  ],

  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'; worker-src 'self';"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "qr-sng@pro-bandey.com",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}
