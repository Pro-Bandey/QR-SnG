{
  "manifest_version": 3,
  "name": "QR Code Scanner & Generator",
  "version": "3.1.5",
  "description": "QR Code Scanner & Generator",
  "author": "Pro Bandey",
  "homepage_url": "https://github.com/MegaMind-Solution",

  "icons": {
    "16": "icons/16.png",
    "32": "icons/32.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  },

  "permissions": [
    "activeTab",
    "contextMenus",
    "sidePanel",
    "storage",
    "clipboardWrite",
    "clipboardRead"
  ],

  "action": {
    "default_icon": {
      "16": "icons/16.png",
      "32": "icons/32.png",
      "48": "icons/48.png",
      "128": "icons/128.png"
    }
  },

  "side_panel": {
    "icons": {
      "48": "icons/48.png"
    },
    "default_path": "index.html"
  },

  "background": {
    "service_worker": "js/background.js"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["js/content.js"]
    }
  ]
}
