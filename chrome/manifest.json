{
  "manifest_version": 3,
  "name": "QR Code Scanner & Generator",
  "description": "QR Code Scanner & Generator",
  "version": "1.0.2",
  "icons": {
    "16": "icons/16.png",
    "32": "icons/32.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  },
  "permissions": [
    "activeTab",
    "contextMenus",
    "sidePanel",
    "storage",
    "clipboardWrite",
    "clipboardRead"
  ],
  "options_ui": {
    "page": "index.html",
    "open_in_tab": false
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_icon": "icons/48.png",
    "default_title": "QR Code Scanner & Generator",
    "default_popup": "index.html"
  },
  "side_panel": {
    "default_path": "index.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}
